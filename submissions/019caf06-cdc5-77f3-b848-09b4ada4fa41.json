{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "con_debater_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "green_google_api_key": {
        "type": "string",
        "secret": true
      },
      "pro_debater_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_google_api_key",
      "pro_debater_openai_api_key",
      "con_debater_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "num_rounds": 1,
          "topic": "AI should be regulated."
        },
        "participant_roles": {
          "green": "green",
          "purple1": "pro_debater",
          "purple2": "con_debater"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/examples/debate/debate-judge.json5",
      "config": {
        "google_api_key": "${config.green_google_api_key}"
      }
    },
    "pro_debater": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/examples/debate/debater.json5",
      "config": {
        "openai_api_key": "${config.pro_debater_openai_api_key}"
      }
    },
    "con_debater": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/examples/debate/debater.json5",
      "config": {
        "openai_api_key": "${config.con_debater_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#pro_debater.a2a"
    },
    {
      "to": "#gateway.purple2",
      "from": "#con_debater.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019caeff-c1de-7770-ae1f-eff2fde43116",
      "pro_debater": "019caf01-7a0e-7ef3-a0b2-4ecb5ff61123",
      "con_debater": "019caf01-7a0e-7ef3-a0b2-4ecb5ff61123"
    }
  }
}